################### Agent conf ###################
### Database ###
AGENT_DB_IP=127.0.0.1
AGENT_DB_PORT=5432
AGENT_DB_USER=user
AGENT_DB_PASS=password
AGENT_DB_NAME=SManagerAgent
AGENT_DATABASE_URL=postgresql://user:password@127.0.0.1:5432/SManagerAgent

### Agent servers parameters ###
AGENT_EXTERN_SERVER_IP=127.0.0.1
AGENT_EXTERN_SERVER_PORT=6969
AGENT_INTERN_SERVER_PORT=7777

################### Core conf ###################
### Database ###
CORE_DB_IP=127.0.0.1
CORE_DB_PORT=5445
CORE_DB_USER=user
CORE_DB_PASS=password
CORE_DB_NAME=SManagerCore
CORE_DATABASE_URL=postgresql://user:password@127.0.0.1:5445/SManagerCore

### Core servers parameters ###
CORE_SERVER_IP=127.0.0.1
CORE_SERVER_PORT=6767

### jwt secret key ###
JWT_SECRET=supersecretkey

### jwt expiration time in seconds ###
### 0 = token never expires ###
JWT_EXPIRATION=86_400

################### Global parameters ###################
### Log level ###
RUST_LOG=debug

### certificates ###
CERTIFICATES_LOCATION=certs/dev/
